# Generated by Cargo
# will have compiled files and executables
debug
target

# Generated WASM build artifacts (wasm-pack output).
# Regenerated from pkg-template/ by build.sh and the release workflow on every
# build/publish; never consumed from git. pkg-template/ is the tracked source.
bindings/sdivi-wasm/pkg/

# TypeScript build info (emitted by tsc incremental mode; excluded via
# "incremental": false in the typecheck tsconfig, but gitignored as a safeguard).
tsconfig.tsbuildinfo
**/tsconfig.tsbuildinfo

# node_modules created by `npm install --no-save typescript@...` during the M47
# consumer-surface typecheck. Not committed; ephemeral CI and local-dev artifact.
node_modules/

# Harness runtime lock/state files
.claude/scheduled_tasks.lock

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

# Generated by cargo mutants
# Contains mutation testing data
**/mutants.out*/

# RustRover
#  JetBrains specific template is maintained in a separate JetBrains.gitignore that can
#  be found at https://github.com/github/gitignore/blob/main/Global/JetBrains.gitignore
#  and can be added to the global gitignore or merged into this file.  For a more nuclear
#  option (not recommended) you can uncomment the following to ignore the entire idea folder.
#.idea/

# Sensitive files
.env
*.pem
*.key
id_rsa
.DS_Store

# Tekhton runtime artifacts
.claude/PIPELINE.lock
.claude/PIPELINE_STATE.md
.claude/MILESTONE_STATE.md
.claude/CHECKPOINT_META.json
.claude/LAST_FAILURE_CONTEXT.json
.claude/TEST_BASELINE.json
.claude/TEST_BASELINE_OUTPUT.txt
.claude/test_acceptance_output.tmp
.claude/dashboard/
.claude/logs/
.claude/indexer-venv/
.claude/index/
.claude/serena/
.serena/
.claude/dry_run_cache/
.claude/migration-backups/
.claude/watchtower_inbox/
.claude/tui_sidecar.pid
.claude/worktrees/
.tekhton/BUILD_FIX_REPORT.md
.tekhton/INTAKE_REPORT.md
.tekhton/NON_BLOCKING_LOG.md
.claude/preflight_bak/

# Editor / OS noise
.idea/
.vscode/
*.swp
*.swo
Thumbs.db
